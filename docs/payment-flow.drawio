<mxfile host="app.diagrams.net" agent="Claude Code" version="24.0.0">
  <diagram id="ton-payment-flow" name="Payment flow">
    <mxGraphModel dx="900" dy="640" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="720" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="TON Payment Gateway — payment flow" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="30" y="8" width="840" height="28" as="geometry" />
        </mxCell>

        <!-- Lifelines -->
        <mxCell id="ll-user" value="User" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="30" y="48" width="140" height="620" as="geometry" />
        </mxCell>
        <mxCell id="ll-bot" value="Bot" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="290" y="48" width="140" height="620" as="geometry" />
        </mxCell>
        <mxCell id="ll-pg" value="Postgres" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="550" y="48" width="140" height="620" as="geometry" />
        </mxCell>
        <mxCell id="ll-ton" value="TON network" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="810" y="48" width="140" height="620" as="geometry" />
        </mxCell>

        <!-- Phase 1: invoice creation -->
        <mxCell id="m1" value="/start" style="html=1;edgeStyle=none;rounded=0;endArrow=block;endFill=1;strokeColor=#333333;fontSize=12;verticalAlign=bottom;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="100" y="130" as="sourcePoint" />
            <mxPoint x="360" y="130" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m2" value="tap &quot;Create&quot; + amount" style="html=1;edgeStyle=none;rounded=0;endArrow=block;endFill=1;strokeColor=#333333;fontSize=12;verticalAlign=bottom;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="100" y="180" as="sourcePoint" />
            <mxPoint x="360" y="180" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m3" value="create invoice INV-7F3A  ·  status = pending" style="html=1;edgeStyle=none;rounded=0;endArrow=block;endFill=1;strokeColor=#333333;fontSize=12;verticalAlign=bottom;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="360" y="230" as="sourcePoint" />
            <mxPoint x="620" y="230" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m4" value="Tonkeeper link + comment" style="html=1;edgeStyle=none;rounded=0;endArrow=open;endFill=0;dashed=1;strokeColor=#333333;fontSize=12;verticalAlign=bottom;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="360" y="280" as="sourcePoint" />
            <mxPoint x="100" y="280" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Phase divider -->
        <mxCell id="div" value="payment &amp; settlement" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#999999;dashed=1;strokeColor=#cccccc;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="290" y="305" width="400" height="20" as="geometry" />
        </mxCell>

        <!-- Phase 2: payment + confirmation -->
        <mxCell id="m5" value="pays in wallet  (comment INV-7F3A)" style="html=1;edgeStyle=none;rounded=0;endArrow=block;endFill=1;strokeColor=#333333;fontSize=12;verticalAlign=bottom;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="100" y="350" as="sourcePoint" />
            <mxPoint x="880" y="350" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m6" value="getTransactions  ·  watcher poll (job queue)" style="html=1;edgeStyle=none;rounded=0;endArrow=block;endFill=1;strokeColor=#333333;fontSize=12;verticalAlign=bottom;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="360" y="410" as="sourcePoint" />
            <mxPoint x="880" y="410" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m7" value="matching transaction" style="html=1;edgeStyle=none;rounded=0;endArrow=open;endFill=0;dashed=1;strokeColor=#333333;fontSize=12;verticalAlign=bottom;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="880" y="460" as="sourcePoint" />
            <mxPoint x="360" y="460" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m8" value="match comment + amount  ·  status = paid" style="html=1;edgeStyle=none;rounded=0;endArrow=block;endFill=1;strokeColor=#333333;fontSize=12;verticalAlign=bottom;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="360" y="510" as="sourcePoint" />
            <mxPoint x="620" y="510" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m9" value="✅ Payment received" style="html=1;edgeStyle=none;rounded=0;endArrow=open;endFill=0;dashed=1;strokeColor=#2e7d32;fontColor=#2e7d32;fontSize=12;fontStyle=1;verticalAlign=bottom;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="360" y="560" as="sourcePoint" />
            <mxPoint x="100" y="560" as="targetPoint" />
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

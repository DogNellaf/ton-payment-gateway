# --- Telegram ---------------------------------------------------------------
# Bot token from @BotFather
BOT_TOKEN=

# --- Database ---------------------------------------------------------------
# Postgres DSN
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ton_gateway

# --- TON --------------------------------------------------------------------
# Receiving (merchant) wallet — PUBLIC address only. No private keys are used.
MERCHANT_WALLET=

# toncenter HTTP API. For testnet use https://testnet.toncenter.com
TON_API_BASE_URL=https://toncenter.com
# API key from @tonapibot (raises rate limits)
TON_API_KEY=

# Tonkeeper deep-link base. For testnet use https://test.tonkeeper.com/transfer
TONKEEPER_TRANSFER_URL=https://app.tonkeeper.com/transfer

# --- Behaviour --------------------------------------------------------------
INVOICE_TTL_MINUTES=30
POLL_INTERVAL_SECONDS=20
MIN_AMOUNT_TON=0.01
MAX_AMOUNT_TON=100
